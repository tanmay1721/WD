<?php
$str = "Hello, Welcome to PHP Programming!";
echo "Original String: " . $str . "<br><br>";
echo "Length: " . strlen($str) . "<br>";
echo "Uppercase: " . strtoupper($str) . "<br>";
echo "Lowercase: " . strtolower($str) . "<br>";
echo "Reversed: " . strrev($str) . "<br>";
echo "Position of 'PHP': " . strpos($str, "PHP") . "<br>";
echo "After Replace: " . str_replace("PHP", "Java", $str) . "<br>";
echo "Substring (0-5): " . substr($str, 0, 5) . "<br>";
$spaceStr = " Hello World ";
echo "Trimmed String: '" . trim($spaceStr) . "'<br>";
echo "Word Count: " . str_word_count($str) . "<br>";
$str2 = "hello, welcome to php programming!";
if (strcasecmp($str, $str2) == 0) {
echo "Strings are equal (case-insensitive)<br>";
} else {
echo "Strings are not equal<br>";
}
?>
