<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSS Styling Example</title>
    
    <!-- External CSS link: Links to styles.css file -->
    <link rel="stylesheet" href="styles.css">

    <!-- Internal CSS: Styles defined within the <style> element for this page only -->
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f4f4; /* Internal style for the body background */
        }
        h1 {
            color: navy; /* Internal style for h1 color */
            border-bottom: 2px solid navy;
            padding-bottom: 10px;
        }
        table {
            width: 80%;
            margin-top: 20px;
            border-collapse: collapse; /* Collapses borders into a single line */
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        /* Zebra-striping for table rows using internal CSS */
        tbody tr:nth-child(even) {
            background-color: #e6e6e6;
        }
    </style>
</head>
<body>

    <h1>Applying CSS Styles</h1>

   
    <h2 style="color: crimson; text-align: center; background-color: #ffcccb; padding: 5px;">Heading with Inline CSS</h2>

    <p>This paragraph is styled by the external CSS file.</p>

    <table>
        <caption>Styled Data Table</caption>
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>John</td>
                <td>Doe</td>
                <td>Developer</td>
            </tr>
            <tr>
                <td>Jane</td>
                <td>Smith</td>
                <td>Designer</td>
            </tr>
            <tr>
              
                <td>Peter</td>
                <td>Jones</td>
                <td style="font-weight: bold; color: green;">Manager</td>
            </tr>
        </tbody>
    </table>

</body>
</html>

